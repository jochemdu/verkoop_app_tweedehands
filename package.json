{
  "name": "verkoopassistent",
  "version": "0.1.0",
  "private": true,
  "description": "Persoonlijke inventaris- en verkoopmanager voor tweedehands spullen — NL markt",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm -F web dev",
    "dev:mobile": "pnpm -F mobile start",
    "build:shared": "pnpm -F @verkoopassistent/shared build",
    "build:mcp": "pnpm -F @verkoopassistent/mcp-server build",
    "db:types": "echo 'Run via Supabase MCP generate_typescript_types and write to packages/shared/src/database.types.ts'",
    "lint": "pnpm -r --parallel --if-present lint",
    "typecheck": "pnpm -r --parallel --if-present typecheck",
    "clean": "pnpm -r --parallel --if-present clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
