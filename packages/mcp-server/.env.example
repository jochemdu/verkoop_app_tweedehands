# MCP Server env vars
# Vereiste waarden voor wanneer je de server lokaal test met
# `pnpm -F @verkoopassistent/mcp-server start` of met de MCP inspector.
#
# Claude Desktop geeft deze zelf door via de `env` key in
# claude_desktop_config.json — dan hoef je dit .env bestand niet te maken.

SUPABASE_URL=https://ffifhjwjauvhohmhhbip.supabase.co
SUPABASE_SERVICE_KEY=<haal op via Supabase Dashboard → Project Settings → API → service_role>
