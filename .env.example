# ──────────────────────────────────────────────────────────────
# VerkoopAssistent — environment variables template
# Kopieer dit bestand naar:
#   - apps/web/.env.local      (voor Next.js)
#   - apps/mobile/.env         (voor Expo)
#   - packages/mcp-server/.env (voor MCP server, Fase 4+)
# Vul de echte waarden in. NOOIT committen!
# ──────────────────────────────────────────────────────────────

# ─── Supabase (gedeeld) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Alleen voor server-side code (Next.js server actions, MCP server).
# NOOIT exposen aan browser of mobiele app.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Next.js web app ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Expo mobile app ────────────────────────────────────────
# Expo vereist EXPO_PUBLIC_ prefix voor runtime access.
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── MCP server (Fase 4+) ───────────────────────────────────
# Wordt door Claude Desktop ingevuld via claude_desktop_config.json.
# Lokaal testen: kopieer hieronder:
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOi...
