NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# In-app AI analyse (server-side; nooit NEXT_PUBLIC_!)
# Maak een key op https://platform.claude.com → API keys
ANTHROPIC_API_KEY=sk-ant-...
# Optioneel: override het model (default claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Gehoste MCP (fase 34) — server-side, nooit NEXT_PUBLIC_!
# service_role key: Supabase Dashboard → Settings → API → service_role (Reveal)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT secret: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# (nodig om per request een user-gescopte token te tekenen voor RLS)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
